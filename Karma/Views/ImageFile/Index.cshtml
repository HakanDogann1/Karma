@model List<EntityLayer.Concrete.ImageFile>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-sm-12 col-xl-12">
    <div class="bg-light rounded h-100 p-4">
        <h6 class="mb-4">Anasayfa Resimleri</h6>
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Başlık</th>
                    <th scope="col">Resim</th>
                    <th scope="col">Sil</th>
                    <th scope="col">Güncelle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {

                    <tr>
                        <th scope="row">@item.ImageFileID</th>
                        <td>@item.ImageFileTitle</td>
                        <td>@item.ImageFileUrl</td>
                        <td><a href="/ImageFile/DeleteImageFile/@item.ImageFileID" class="btn btn-outline-danger">Sil</a></td>
                        <td><a href="/ImageFile/UpdateImageFile/@item.ImageFileID" class="btn btn-outline-warning">Güncelle</a></td>
                    </tr>

                }
            </tbody>
        </table>
        <a href="/ImageFile/AddImageFile/" class="btn btn-outline-primary">Yeni Başlık Ekle</a>
    </div>
</div>


