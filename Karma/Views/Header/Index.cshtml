@model List<EntityLayer.Concrete.Header>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    string color = "";
}

<div class="col-sm-12 col-xl-12">
    <div class="bg-light rounded h-100 p-4">
        <h6 class="mb-4">Sayfa Başlığı</h6>
        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Sayfa Başlığı 1</th>
                    <th scope="col">Sayfa Başlığı 2</th>
                    <th scope="col">Başlık Resim</th>
                    <th scope="col">Deneme</th>
                    <th scope="col">Durum</th>
                    <th scope="col">Aktif Yap</th>
                    <th scope="col">Pasif Yap</th>
                    <th scope="col">Güncelle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {

                    <tr>
                        <th scope="row">@item.HeaderID</th>
                        <td>@item.HeaderTitle1</td>
                        <td>@item.HeaderTitle2</td>
                        <td>@item.HeaderImageUrl</td>
                        <td> @ViewBag.HeaderStatus</td>
                        @if (item.HeaderStatus == true)
                        {
                            color = "green";
                        }
                        else
                        {
                            color = "red";
                        }
                        <td> <div class="badge badge-danger" style="color:@color;">@item.HeaderStatus </div></td>
                      
                        <td><a href="/Header/AktifHeader/@item.HeaderID" class="btn btn-outline-success">Aktif Yap</a></td>
                        <td><a href="/Header/PasifHeader/@item.HeaderID" class="btn btn-outline-danger">Pasif Yap</a></td>
                        <td><a href="/Header/UpdateHeader/@item.HeaderID" class="btn btn-outline-warning">Güncelle</a></td>
                    </tr>

                }
            </tbody>
        </table>
        <a href="/Header/AddHeader/" class="btn btn-outline-primary">Yeni Başlık Ekle</a>
    </div>
</div>


